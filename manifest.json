{
  "manifest_version": 3,
  "name": "Agentic Job Scout",
  "version": "0.1.0",
  "description": "AI Agent that auto-collects AI Engineer campus/intern job postings from LinkedIn, Indeed, and Boss直聘, then exports to CSV.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "downloads"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.linkedin.cn/*",
    "https://www.indeed.com/*",
    "https://www.zhipin.com/*",
    "https://api.openai.com/*",
    "https://api.deepseek.com/*"
  ],
  "background": {
    "service_worker": "src/background/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://www.linkedin.cn/*",
        "https://www.indeed.com/*",
        "https://www.zhipin.com/*"
      ],
      "js": ["src/content_script/content.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Agentic Job Scout"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
